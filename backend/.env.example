# Copy this file to .env for local `cargo run` - loaded automatically via
# dotenvy (GH issue #2 Phase 5). Docker/Fly ignore this file entirely and
# expect real env vars injected directly (fly secrets set / docker-compose).

DATABASE_URL=postgres://postgres:postgres@localhost:5432/livecode

# STUB: dev-only placeholder. Every route except /hello requires this exact
# value in an `X-Internal-Key` header - see the comment in src/main.rs.
# ysocket must be configured with the same value (its INTERNAL_API_KEY).
# Set a real random secret, shared with ysocket, for any non-local deployment.
INTERNAL_API_KEY=livecode-dev-stub-internal-key

# Listen port. Fly.io assigns this via $PORT; defaults to 3000 if unset.
PORT=3000
