# Copy this file to .env for local `cargo run` - loaded automatically via
# dotenvy (GH issue #2 Phase 5). Docker/Fly ignore this file entirely and
# expect real env vars injected directly (fly secrets set / docker-compose).

DATABASE_URL=postgres://postgres:postgres@localhost:5432/livecode

# STUB: no real Firebase project exists yet (Phase 6 of GH issue #2). Any
# string works for local boot - see the comment in src/main.rs. Auth-protected
# routes (e.g. GET /me) will reject every token until this is a real project id.
FIREBASE_PROJECT_ID=livecode-dev-stub

# Comma-separated allow-list of frontend origins allowed to call this API.
# Defaults to http://localhost:5173 (the Vite dev server) if unset - see the
# comment in src/main.rs. Set to the real Cloudflare Pages domain(s) for any
# non-local deployment.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Listen port. Fly.io assigns this via $PORT; defaults to 3000 if unset.
PORT=3000
