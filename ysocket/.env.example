# Copy this file to .env for local `npm start` - loaded automatically via
# dotenv (GH issue #2 Phase 5). Docker/Fly ignore this file entirely and
# expect real env vars injected directly (fly secrets set / docker-compose).

# STUB: no real Firebase project exists yet (Phase 6 of GH issue #2). Any
# string works for local boot - see the comment in server.js. All WS upgrades
# will be rejected until this is a real project id (GH issue #2 Phase 4).
FIREBASE_PROJECT_ID=livecode-dev-stub

BACKEND_URL=http://localhost:3000

# STUB: dev-only placeholder. Must match the backend's INTERNAL_API_KEY
# exactly - see the comment in server.js and backend/src/auth.rs.
INTERNAL_API_KEY=livecode-dev-stub-internal-key

# Listen port/host. Fly.io assigns PORT via $PORT; HOST defaults to 0.0.0.0
# (required to accept connections from outside its own container) if unset.
PORT=1234
HOST=0.0.0.0
