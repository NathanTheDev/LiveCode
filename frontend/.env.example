# not secrets. Get real values from the Firebase console once the project is
# created, and copy this file to .env.
VITE_FIREBASE_API_KEY=stub-api-key
VITE_FIREBASE_AUTH_DOMAIN=stub-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=stub-project
VITE_FIREBASE_APP_ID=stub-app-id
