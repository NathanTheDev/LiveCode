# STUB: no real Firebase project exists yet (Phase 6 of GH issue #2). These
# are Firebase's public web client config - safe to expose in a client bundle,
# not secrets. Get real values from the Firebase console once the project is
# created, and copy this file to .env.
VITE_FIREBASE_API_KEY=stub-api-key
VITE_FIREBASE_AUTH_DOMAIN=stub-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=stub-project
VITE_FIREBASE_APP_ID=stub-app-id

# Optional, local dev only: point the client SDK at the Firebase Auth Emulator
# (`npx firebase emulators:start --only auth`) instead of real Firebase, so
# sign up/in/out can be tested without a real project. Leave unset otherwise.
# VITE_FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
